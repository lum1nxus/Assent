{
  "name": "assent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Reads the Terms of Service so you don't have to. Shows a risk score before you click 'I Agree'.",
  "homepage": "https://github.com/lum1nxus/Assent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lum1nxus/Assent.git"
  },
  "license": "MIT",
  "scripts": {
    "lint": "eslint extension/src tests",
    "format": "prettier --write \"**/*.{js,json,html,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,json,html,md}\" --ignore-path .prettierignore",
    "test": "node --test tests/*.test.js",
    "zip": "rm -f assent-*.zip && cd extension && zip -r ../assent-${npm_package_version}.zip . -x '*.DS_Store' '*/.DS_Store'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
